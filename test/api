const request = require('supertest');
const app = require('../src/app');

describe('Bands API Endpoints', () => {
  
  describe('GET /bands', () => {
    it('deve retornar a lista de bandas de rock e status 200', async () => {
      const res = await request(app).get('/bands');
      
      expect(res.statusCode).toEqual(200);
      expect(Array.isArray(res.body.data)).toBe(true);
      expect(res.body).toHaveProperty('total');
      expect(res.body).toHaveProperty('page');
    });

    it('deve filtrar bandas por gênero musical', async () => {
      const res = await request(app).get('/bands?genre=Grunge');
      
      expect(res.statusCode).toEqual(200);
      if (res.body.data.length > 0) {
        expect(res.body.data[0].genre).toBe('Grunge');
      }
    });
  });

});
